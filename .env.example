# -----------------------------------------------------------------------
# Anthropic API
# Erstellen unter: https://console.anthropic.com/keys
# -----------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------
# Supabase (self-hosted auf Hetzner via Coolify)
# SUPABASE_URL:              z.B. https://db.iris.sasserath-bitter.de
# SUPABASE_SERVICE_ROLE_KEY: Im Supabase-Dashboard unter Settings → API
#                            → service_role (NIEMALS im Browser verwenden)
# -----------------------------------------------------------------------
SUPABASE_URL=https://db.iris.sasserath-bitter.de
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# -----------------------------------------------------------------------
# Teams Bot (Phase 2 – optional)
# MICROSOFT_APP_ID:       Azure App Registration → Application (client) ID
# MICROSOFT_APP_PASSWORD: Azure App Registration → Certificates & secrets → Client secret
# TEAMS_AAD_ID_THOMAS:    Teams AAD Object ID von Thomas (aus erstem Bot-Kontakt)
# TEAMS_AAD_ID_BEATE:     Teams AAD Object ID von Beate (aus erstem Bot-Kontakt)
# Messaging Endpoint:     https://DOMAIN/api/teams/messages
# -----------------------------------------------------------------------
MICROSOFT_APP_ID=
MICROSOFT_APP_PASSWORD=
MICROSOFT_TENANT_ID=
TEAMS_AAD_ID_THOMAS=
TEAMS_AAD_ID_BEATE=
PLANNER_PLAN_ID_THOMAS=
PLANNER_PLAN_ID_BEATE=

# -----------------------------------------------------------------------
# Lokale Entwicklung:
#   cp .env.example .env.local
#   Werte eintragen, dann: npm run dev
# -----------------------------------------------------------------------
